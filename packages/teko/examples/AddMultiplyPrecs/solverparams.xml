<ParameterList>
  <Parameter name="Linear Solver Type" type="string" value="Amesos2"/>

  <ParameterList name="Linear Solver Types">
    <ParameterList name="Amesos2">
      <Parameter name="Solver Type" type="string" value="KLU2"/>
      <Parameter name="Throw on Preconditioner Input" type="bool" value="true"/>
      <ParameterList name="VerboseObject">
        <Parameter name="Output File" type="string" value="none"/>
        <Parameter name="Verbosity Level" type="string" value="default"/>
      </ParameterList>
    </ParameterList>
  </ParameterList>

  <Parameter name="Preconditioner Type" type="string" value="Ifpack2"/>

  <ParameterList name="Preconditioner Types">
    <ParameterList name="Ifpack2">
      <Parameter name="Prec Type" type="string" value="ILUT"/>
      <Parameter name="Overlap" type="int" value="0"/>
      <ParameterList name="Ifpack2 Settings">
        <Parameter name="fact: ilut level-of-fill" type="double" value="1.0"/>
        <Parameter name="fact: drop tolerance" type="double" value="0.0"/>
      </ParameterList>
    </ParameterList>
  </ParameterList>
</ParameterList>